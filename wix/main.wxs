<?xml version='1.0' encoding='windows-1252'?>

<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <!--
      Tokens rewritten by scripts/new_app.ps1:
        TinyBooth Sound Studio       : display name (e.g. "My App")
        tinyboothsoundstudio       : lowercase folder name (e.g. "myapp")
        tinybooth-sound-studio        : executable name without .exe (matches Cargo `[[bin]]`)
        ophiocus
        Channel recorder, visualizer, and TinyBooth project exporter
        https://github.com/ophiocus/TinyBoothSoundStudio
        48D329DD-B504-46C4-B23E-D3FDD71F4ABE   : fresh UUID per app
        E5C50DF6-615E-4200-85BF-46AA131EF965
        374063C9-D0B6-4E16-A3EB-BA80A6D47E8B
    -->
    <Product
        Id='*'
        Name='TinyBooth Sound Studio'
        UpgradeCode='48D329DD-B504-46C4-B23E-D3FDD71F4ABE'
        Manufacturer='ophiocus'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='Channel recorder, visualizer, and TinyBooth project exporter'
            Manufacturer='ophiocus'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'
            />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            AllowSameVersionUpgrades='yes'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='tinyboothsoundstudio Installation'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformProgramFilesFolder)' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='tinyboothsoundstudio'>

                    <Directory Id='Bin' Name='bin'>
                        <Component Id='Path' Guid='E5C50DF6-615E-4200-85BF-46AA131EF965' KeyPath='yes'>
                            <Environment
                                Id='PATH'
                                Name='PATH'
                                Value='[Bin]'
                                Permanent='no'
                                Part='last'
                                Action='set'
                                System='yes'/>
                        </Component>
                        <Component Id='binary0' Guid='*'>
                            <File
                                Id='exe0'
                                Name='tinybooth-sound-studio.exe'
                                DiskId='1'
                                Source='$(var.CargoTargetBinDir)\tinybooth-sound-studio.exe'
                                KeyPath='yes'/>
                        </Component>
                        <!--
                          Bundled static LGPL ffmpeg (v0.4.10). The CI
                          workflow downloads BtbN's nightly LGPL build,
                          extracts the single .exe, and drops it next
                          to the main binary. TinyBooth's export.rs
                          discovery checks `<exe_dir>\ffmpeg.exe`
                          first, so this lights up FLAC / MP3 / Ogg /
                          M4A export immediately on a fresh install
                          with no user setup. ~120 MB on disk — the
                          single biggest contributor to install size,
                          worth it for the "Just Works" feel.
                        -->
                        <Component Id='binary_ffmpeg' Guid='*'>
                            <File
                                Id='ffmpeg_exe'
                                Name='ffmpeg.exe'
                                DiskId='1'
                                Source='$(var.CargoTargetBinDir)\ffmpeg.exe'
                                KeyPath='yes'/>
                        </Component>
                    </Directory>

                    <Component Id='DesktopShortcut' Guid='374063C9-D0B6-4E16-A3EB-BA80A6D47E8B'>
                        <Shortcut Id='DesktopShortcut'
                            Name='TinyBooth Sound Studio'
                            Description='Channel recorder, visualizer, and TinyBooth project exporter'
                            Directory='DesktopFolder'
                            Target='[Bin]tinybooth-sound-studio.exe'
                            WorkingDirectory='Bin'
                            Icon='ProductICO' />
                        <RegistryValue Root='HKCU'
                            Key='Software\ophiocus\TinyBooth Sound Studio'
                            Name='DesktopShortcut'
                            Type='integer'
                            Value='1'
                            KeyPath='yes' />
                    </Component>
                </Directory>
            </Directory>
            <Directory Id='DesktopFolder' Name='Desktop' />
        </Directory>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs the application binary.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>
            <ComponentRef Id='binary0'/>
            <ComponentRef Id='binary_ffmpeg'/>
            <ComponentRef Id='DesktopShortcut'/>

            <Feature
                Id='Environment'
                Title='PATH Environment Variable'
                Description='Add the install location to the PATH system environment variable.'
                Level='1'
                Absent='allow'>
                <ComponentRef Id='Path'/>
            </Feature>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <Icon Id='ProductICO' SourceFile='assets\icon.ico'/>
        <Property Id='ARPPRODUCTICON' Value='ProductICO' />
        <Property Id='ARPHELPLINK' Value='https://github.com/ophiocus/TinyBoothSoundStudio'/>

        <!--
          Launch-after-install custom action (v0.4.6).

          The in-app self-updater (src/git_update.rs) shells out to
          `msiexec /i ... /passive /norestart` via a RunAs PowerShell.
          The old TinyBooth process exits as soon as msiexec is
          spawned so the install can replace the running .exe. By
          default the MSI then ends silently — the user is left
          staring at the desktop with the app gone. This custom
          action relaunches the new exe at the end of a successful
          install so the user lands back where they were.

          Type 18 custom action (FileKey + ExeCommand): runs the
          installed exe directly without needing WixUtilExtension,
          which `cargo-wix` doesn't enable by default. Execute=
          "immediate" + Impersonate="yes" runs the launched app in
          the user's session at user-level integrity, not as SYSTEM
          / elevated. Return="asyncNoWait" so msiexec doesn't sit
          blocked on the long-running app process.

          Conditions:
            UILevel >= 3   — fires for /passive, /qr, /qf, full UI;
                              skips silent /qn corporate deploys.
                              The self-updater uses /passive (3).
            NOT Installed  — fires for fresh install + major-upgrade
                              new-install phase; skips repair,
                              uninstall, modify (where launching the
                              app would be unwelcome).
        -->
        <CustomAction Id='LaunchApplication'
                      FileKey='exe0'
                      ExeCommand=''
                      Execute='immediate'
                      Impersonate='yes'
                      Return='asyncNoWait'/>

        <InstallExecuteSequence>
            <Custom Action='LaunchApplication' After='InstallFinalize'>UILevel &gt;= 3 AND NOT Installed</Custom>
        </InstallExecuteSequence>

        <UI>
            <UIRef Id='WixUI_FeatureTree'/>
            <Publish Dialog='WelcomeDlg' Control='Next' Event='NewDialog' Value='CustomizeDlg' Order='99'>1</Publish>
            <Publish Dialog='CustomizeDlg' Control='Back' Event='NewDialog' Value='WelcomeDlg' Order='99'>1</Publish>
        </UI>

    </Product>

</Wix>
